 top: 0;\n  left: 0;\n  right: 0;\n  z-index: 9999;\n  padding: 12px 16px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 14px;\n  font-weight: 500;\n  animation: slideDown 0.3s ease-out;\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);\n}\n\n/* Offline state - Warning colors */\n.network-banner.offline {\n  background-color: #FFF4E6; /* Light orange background */\n  border-bottom: 2px solid #f59e0b; /* Gold/warning border */\n  color: #92400e; /* Dark orange text */\n}\n\n/* Online state - Success colors */\n.network-banner.online {\n  background-color: #D1FAE5; /* Light green background */\n  border-bottom: 2px solid #10b981; /* Success green border */\n  color: #065F46; /* Dark green text */\n}\n\n.network-banner__content {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  max-width: 1200px;\n  margin: 0 auto;\n}\n\n.network-banner__icon {\n  font-size: 18px;\n  line-height: 1;\n  flex-shrink: 0;\n}\n\n.network-banner__text {\n  line-height: 1.4;\n}\n\n/* Slide down animation */\n@keyframes slideDown {\n  from {\n    transform: translateY(-100%);\n    opacity: 0;\n  }\n  to {\n    transform: translateY(0);\n    opacity: 1;\n  }\n}\n\n/* Dark mode support */\n@media (prefers-color-scheme: dark) {\n  .network-banner.offline {\n    background-color: rgba(245, 158, 11, 0.15);\n    border-bottom-color: #f59e0b;\n    color: #fcd34d;\n  }\n\n  .network-banner.online {\n    background-color: rgba(16, 185, 129, 0.15);\n    border-bottom-color: #10b981;\n    color: #6ee7b7;\n  }\n\n  .network-banner {\n    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);\n  }\n}\n\n/* Mobile responsive adjustments */\n@media (max-width: 640px) {\n  .network-banner {\n    padding: 10px 12px;\n    font-size: 13px;\n  }\n\n  .network-banner__icon {\n    font-size: 16px;\n  }\n\n  .network-banner__text {\n    font-size: 13px;\n  }\n}\n\n/* Tablet adjustments */\n@media (min-width: 641px) and (max-width: 1024px) {\n  .network-banner {\n    padding: 11px 14px;\n  }\n}\n\n/* High contrast mode support */\n@media (prefers-contrast: high) {\n  .network-banner.offline {\n    background-color: #fff;\n    border-bottom-width: 3px;\n    color: #000;\n  }\n\n  .network-banner.online {\n    background-color: #fff;\n    border-bottom-width: 3px;\n    color: #000;\n  }\n}\n\n/* Reduced motion support */\n@media (prefers-reduced-motion: reduce) {\n  .network-banner {\n    animation: none;\n  }\n}\n"],["STYLE",{},"*, ::before, ::after {\n  --tw-border-spacing-x: 0;\n  --tw-border-spacing-y: 0;\n  --tw-translate-x: 0;\n  --tw-translate-y: 0;\n  --tw-rotate: 0;\n  --tw-skew-x: 0;\n  --tw-skew-y: 0;\n  --tw-scale-x: 1;\n  --tw-scale-y: 1;\n  --tw-pan-x:  ;\n  --tw-pan-y:  ;\n  --tw-pinch-zoom:  ;\n  --tw-scroll-snap-strictness: proximity;\n  --tw-gradient-from-position:  ;\n  --tw-gradient-via-position:  ;\n  --tw-gradient-to-position:  ;\n  --tw-ordinal:  ;\n  --tw-slashed-zero:  ;\n  --tw-numeric-figure:  ;\n  --tw-numeric-spacing:  ;\n  --tw-numeric-fraction:  ;\n  --tw-ring-inset:  ;\n  --tw-ring-offset-width: 0px;\n  --tw-ring-offset-color: #fff;\n  --tw-ring-color: rgb(59 130 246 / 0.5);\n  --tw-ring-offset-shadow: 0 0 #0000;\n  --tw-ring-shadow: 0 0 #0000;\n  --tw-shadow: 0 0 #0000;\n  --tw-shadow-colored: 0 0 #0000;\n  --tw-blur:  ;\n  --tw-brightness:  ;\n  --tw-contrast:  ;\n  --tw-grayscale:  ;\n  --tw-hue-rotate:  ;\n  --tw-invert:  ;\n  --tw-saturate:  ;\n  --tw-sepia:  ;\n  --tw-drop-shadow:  ;\n  --tw-backdrop-blur:  ;\n  --tw-backdrop-brightness:  ;\n  --tw-backdrop-contrast:  ;\n  --tw-backdrop-grayscale:  ;\n  --tw-backdrop-hue-rotate:  ;\n  --tw-backdrop-invert:  ;\n  --tw-backdrop-opacity:  ;\n  --tw-backdrop-saturate:  ;\n  --tw-backdrop-sepia:  ;\n  --tw-contain-size:  ;\n  --tw-contain-layout:  ;\n  --tw-contain-paint:  ;\n  --tw-contain-style:  ;\n}\n\n::backdrop {\n  --tw-border-spacing-x: 0;\n  --tw-border-spacing-y: 0;\n  --tw-translate-x: 0;\n  --tw-translate-y: 0;\n  --tw-rotate: 0;\n  --tw-skew-x: 0;\n  --tw-