-status-passed {\n    background-color: rgb(var(--color-status-passed));\n  }\n/* Hide scrollbar but keep functionality */\n/* Custom scrollbar styling */\n/* Responsive container utilities */\n/* Section heading divider — used on LandingPage and module section titles */\n.section-heading {\n  margin-bottom: 1rem;\n  border-bottom-width: 1px;\n  --tw-border-opacity: 1;\n  border-color: rgb(229 231 235 / var(--tw-border-opacity, 1));\n  padding-bottom: 0.5rem;\n  font-size: 0.75rem;\n  line-height: 1rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  --tw-text-opacity: 1;\n  color: rgb(107 114 128 / var(--tw-text-opacity, 1));\n}\n.section-heading:is(.dark *) {\n  --tw-border-opacity: 1;\n  border-color: rgb(55 65 81 / var(--tw-border-opacity, 1));\n  --tw-text-opacity: 1;\n  color: rgb(156 163 175 / var(--tw-text-opacity, 1));\n}\n/* Toast enter animation */\n.animate-toast-enter {\n    animation: toastEnter 0.22s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;\n  }\n@keyframes toastEnter {\n    from {\n      opacity: 0;\n      transform: translateY(0.75rem) scale(0.96);\n    }\n    to {\n      opacity: 1;\n      transform: translateY(0) scale(1);\n    }\n  }\n\n/* Print styles */\n@media print {\n  body {\n    --tw-bg-opacity: 1;\n    background-color: rgb(255 255 255 / var(--tw-bg-opacity, 1));\n    --tw-text-opacity: 1;\n    color: rgb(0 0 0 / var(--tw-text-opacity, 1));\n  }\n\n  .no-print {\n    display: none !important;\n  }\n\n  /* Ensure proper page breaks */\n  .page-break-before {\n    page-break-before: always;\n  }\n\n  .page-break-after {\n    page-break-after: always;\n  }\n\n  .page-break-avoid {\n    page-break-inside: avoid;\n  }\n}\n\n/* Reduced motion for accessibility */\n@media (prefers-reduced-motion: reduce) {\n  *,\n  *::before,\n  *::after {\n    animation-duration: 0.01ms !important;\n    animation-iteration-count: 1 !important;\n    transition-duration: 0.01ms !important;\n    scroll-behavior: auto !important;\