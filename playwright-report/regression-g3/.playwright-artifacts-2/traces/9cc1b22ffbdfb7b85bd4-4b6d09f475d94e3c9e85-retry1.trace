{"type":"before","callId":"call@31","startTime":44000.536,"class":"Frame","method":"evaluateExpression","params":{"expression":"rid => {\n    const key = 'race-tracker-storage';\n    const stored = JSON.parse(localStorage.getItem(key) || '{\"state\":{}}');\n    stored.state = {\n      ...stored.state,\n      selectedRaceForMode: rid,\n      currentRaceId: rid\n    };\n    localStorage.setItem(key, JSON.stringify(stored));\n  }","isFunction":true,"arg":{"value":{"n":1},"handles":[]}},"stepId":"pw:api@48","pageId":"page@07d5ee7c553a074e3b49b1b7875d65a9","beforeSnapshot":"before@call@31"}
